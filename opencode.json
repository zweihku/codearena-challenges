{
  "$schema": "https://opencode.ai/config.json",
  "model": "zhipuai/glm-5.1",
  "small_model": "zhipuai/glm-4.5-flash",
  "autoupdate": false,
  "share": "disabled",
  "provider": {
    "zhipuai": {
      "options": {
        "chunkTimeout": 120000
      }
    }
  },
  "permission": {
    "read": {
      "*CHALLENGE*": "deny",
      "*RUBRIC*": "deny",
      "*rubric*": "deny"
    }
  },
  "mode": {
    "build": {
      "temperature": 0.3,
      "permission": {
        "read": {
          "*CHALLENGE*": "deny",
          "*RUBRIC*": "deny"
        }
      }
    },
    "plan": {
      "temperature": 0.3,
      "permission": {
        "read": {
          "*CHALLENGE*": "deny",
          "*RUBRIC*": "deny"
        }
      }
    }
  },
  "instructions": ["AGENTS.md"]
}
